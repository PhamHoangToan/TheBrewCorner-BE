DATABASE_URL="mysql://root:password@localhost:3306/the_brew_corner"
PORT=3000
ATTENDANCE_API_KEY=changeme

# JWT auth — BẮT BUỘC set trên production (Render). Nếu thiếu, BE dùng secret mặc định (không an toàn).
# JWT_EXPIRES: thời hạn token, mặc định 30d.
JWT_SECRET=changeme-use-a-long-random-string
JWT_EXPIRES=30d

# Gmail SMTP — dùng để gửi email tài khoản cho nhân viên mới (Staff > Thêm nhân viên)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Casso webhook — bắt buộc, dùng để xác thực POST /api/webhooks/casso qua header x-api-key
CASSO_API_KEY=changeme

# Resend API — đường chính gửi email (Render chặn SMTP). Lấy tại resend.com
RESEND_API_KEY=

# Quên mật khẩu — base URL trang đặt lại mật khẩu (FE nội bộ). Link gửi: {APP_RESET_URL}?token=...
# Local: http://localhost:5174/reset-password  |  Production: https://<fe-vercel>/reset-password
APP_RESET_URL=http://localhost:5174/reset-password

# FCM push mobile — Server key (legacy) từ Firebase Console. Thiếu → push tự no-op (không lỗi).
FCM_SERVER_KEY=
